{
  "name": "github-updater",
  "version": "1.0.0",
  "description": "Auto-updater toolbox for your GitHub apps",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --publish never",
    "build:local": "electron-builder --win --dir --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "release": "electron-builder --win --publish always",
    "release:linux": "electron-builder --linux --publish always"
  },
  "keywords": ["github", "updater", "toolbox"],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-fetch": "^2.7.0"
  },
  "build": {
    "appId": "com.yourname.github-updater",
    "productName": "GitHub Updater",
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "apps-config/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "Alowster",
      "repo": "github-updater"
    }
  }
}
